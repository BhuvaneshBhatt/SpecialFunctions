    "\n",
    "ax.text(0.5, 0.31, r\"$\\mathrm{Classical\\ polylogs} \\subset \\mathrm{HPLs} \\subset \\mathrm{MPLs} \\subset \\mathrm{Iterated\\ integrals}$\",\n",
    "        ha=\"center\", va=\"center\", fontsize=12)\n",
    "ax.text(0.5, 0.24, r\"$\\mathrm{MZVs}$ arise as special values of $\\mathrm{MPLs}$.\",\n",
    "        ha=\"center\", va=\"center\", fontsize=12)\n",
    "ax.text(0.5, 0.17, r\"Beyond the polylogarithmic world, many Feynman integrals require elliptic or more general functions.\",\n",
    "        ha=\"center\", va=\"center\", fontsize=12)\n",
